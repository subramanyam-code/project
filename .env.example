# ══════════════════════════════════════════════════
#  TSPM — Environment Variables Template
#  Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────
POSTGRES_USER=mydata
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=hidb
POSTGRES_PORT=5432
DATABASE_URL=postgresql://mydata:mypassword@localhost:5432/hidb

# ── Redis ──────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ── Local service ports ────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
PGADMIN_PORT=5050

# ── pgAdmin (local only) ───────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ── JWT ────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your-super-secret-key-at-least-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AWS S3 (optional — for file uploads) ──────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1

# ── Email / SMTP (optional) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@yourdomain.com

# ── App URLs ───────────────────────────────────────
# Local development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Production — fill these in after deploying
# FRONTEND_URL=https://your-site.netlify.app
# BACKEND_URL=https://tspm-backend.onrender.com
# BACKEND_CORS_ORIGINS=https://your-site.netlify.app

# ── Frontend (Next.js) ─────────────────────────────
# Local dev — points directly to backend
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production — leave blank or set to Netlify site URL
# (frontend calls /api/* which Netlify proxies to Render)
# NEXT_PUBLIC_API_URL=https://your-site.netlify.app
NEXT_PUBLIC_APP_NAME=TeamStatus

# ── Environment ────────────────────────────────────
ENVIRONMENT=development
# ENVIRONMENT=production

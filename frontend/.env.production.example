# Production Environment Variables for Netlify

# Backend API URL - Replace with your deployed backend URL
# Example: https://your-app.onrender.com/api/v1
# Example: https://your-app.fly.dev/api/v1
NEXT_PUBLIC_API_URL=https://your-backend-url.com/api/v1

# App Configuration
NEXT_PUBLIC_APP_NAME=TSPM - Team & Project Management

# Optional: Analytics, Error Tracking, etc.
# NEXT_PUBLIC_GA_ID=your-google-analytics-id
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
